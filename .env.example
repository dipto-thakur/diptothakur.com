# Site URL (used for sitemap + OG metadata)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ImageKit (optional — placeholders render without this)
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/xonqtzzvs

# Analytics — Plausible (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# Analytics — Umami (optional, alternative to Plausible)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-id
NEXT_PUBLIC_UMAMI_URL=https://analytics.yourdomain.com/script.js
